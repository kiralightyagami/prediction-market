// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String         @id @default(uuid())
  address    String         @unique
  usdBalance Int
  positions  Position[]
  orders     OrderHistory[]

  @@index([address])
}

model Market {
  id           String         @id @default(uuid())
  title        String
  description  String
  resolve      String
  yesOrderbook Json
  noOrderbook  Json
  totalQty     Int
  resolution   PositionType?
  positions    Position[]
  orders       OrderHistory[]
}

model Position {
  id       String       @id @default(uuid())
  userId   String
  marketId String
  qty      Int
  type     PositionType
  user     User         @relation(fields: [userId], references: [id])
  market   Market       @relation(fields: [marketId], references: [id])
  @@unique([userId, marketId, type])
}

model OrderHistory {
  id        String    @id @default(uuid())
  orderType OrderType
  qty       Int
  price     Int
  userId    String
  marketId  String

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])
}

//  ======== ENUMS ========

enum PositionType {
  Yes
  No
}

enum OrderType {
  Buy
  Sell
  Split
  Merges
}
